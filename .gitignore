# ==============================================================================
# NYDUSNET SPECIFIC (Added for Security & Local Dev)
# ==============================================================================

# --- SSH & Security Credentials ---
# Critical: Prevent committing generated keys or tunnel credentials
*.pem
*.key
*.pub
known_hosts
authorized_keys
id_rsa
id_rsa.pub

# --- Syncthing Runtime ---
# Ignores runtime config generated during local testing
syncthing.exe
syncthing-config/
.stfolder/

# --- Local Logs ---
# NydusNet custom logs
logs/
*.log

# --- Build Artifacts ---
# Binaries generated by PyInstaller or Inno Setup
*.exe
*.installer.exe

# --- Local Configuration ---
# If you use local config files for dev that shouldn't be pushed
config.json
settings.yaml
verification.dat
